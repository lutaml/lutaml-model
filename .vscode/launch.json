{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "ruby_lsp",
            "name": "Debug script",
            "request": "launch",
            "program": "ruby ${file}"
        },
        {
            "type": "ruby_lsp",
            "name": "Debug all specs",
            "request": "launch",
            "program": "rspec"
        },
        {
            "type": "ruby_lsp",
            "name": "Debug lib file",
            "request": "launch",
            "program": "${workspaceFolder}/lib/lutaml/model/serialize.rb"
        },
        {
            "type": "ruby_lsp",
            "name": "Attach debugger",
            "request": "attach"
        }
    ]
}
